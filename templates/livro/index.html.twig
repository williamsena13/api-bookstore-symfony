{% extends 'admin/layout.html.twig' %}

{% block title %}Livros — {{ livraria.nome ?? 'Bookstore' }}{% endblock %}
{% block page_title %}Livros{% endblock %}
{% block breadcrumb %}<i class="pi pi-angle-right"></i> Livros{% endblock %}

{% block content %}
<div class="p-card">
    <div class="p-card-header">
        <h2 class="p-card-title"><i class="pi pi-book"></i> Livros</h2>
        <button class="p-btn p-btn-success p-btn-sm btn-modal" data-url="{{ path('app_livro_new') }}" data-title="Novo Livro">
            <i class="pi pi-plus"></i> Novo Livro
        </button>
    </div>
    <div class="p-card-body">
        <div class="dt-wrapper">
            <table class="p-datatable w-full" data-sortable="[0,1,2,3,4,5]">
                <thead>
                    <tr><th>#</th><th>Título</th><th>Autores</th><th>Editora</th><th>Ano</th><th>Ed.</th><th>Preço</th><th>Ações</th></tr>
                </thead>
                <tbody>
                    {% for livro in livros %}
                    <tr>
                        <td>{{ livro.id }}</td>
                        <td>
                            <strong>{{ livro.titulo }}</strong>
                            {% if livro.isbn %}<br><small style="color:var(--text-secondary);">ISBN: {{ livro.isbn }}</small>{% endif %}
                        </td>
                        <td>{{ livro.autores|map(a => a.nome)|join(', ') }}</td>
                        <td>{{ livro.editora ?? '—' }}</td>
                        <td>{{ livro.anoPublicacao ?? '—' }}</td>
                        <td>{{ livro.edicao ? livro.edicao ~ 'ª' : '—' }}</td>
                        <td>
                            {% if livro.preco %}
                                <span style="color:var(--success);font-weight:600;">R$ {{ livro.preco|number_format(2, ',', '.') }}</span>
                            {% else %}—{% endif %}
                        </td>
                        <td>
                            <div class="flex gap-2">
                                <button class="p-btn p-btn-warning p-btn-sm btn-modal" data-url="{{ path('app_livro_edit', {id: livro.id}) }}" data-title="Editar Livro">
                                    <i class="pi pi-pencil"></i>
                                </button>
                                <form method="post" action="{{ path('app_livro_delete', {id: livro.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ livro.id) }}">
                                    <button type="button" class="p-btn p-btn-danger p-btn-sm btn-delete" data-label='"{{ livro.titulo }}"'>
                                        <i class="pi pi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="8" class="text-center" style="color:var(--text-secondary);padding:2rem;">Nenhum livro cadastrado.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% include 'admin/_modals.html.twig' with { modal_size: 'modal-lg' } %}
{% endblock %}

{% block javascripts %}
<script src="/js/datatable.js"></script>
<script src="/js/modal-crud.js"></script>
{% endblock %}
