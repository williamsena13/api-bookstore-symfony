{% extends 'admin/layout.html.twig' %}

{% block title %}{{ title }} — Bookstore{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>{{ title }}</h2>
    <a href="{{ path('app_livro_index') }}" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Voltar</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        {{ form_start(form) }}
            <div class="row">
                <div class="col-md-8 mb-3">{{ form_row(form.titulo) }}</div>
                <div class="col-md-4 mb-3">{{ form_row(form.isbn) }}</div>
            </div>
            <div class="row">
                <div class="col-md-4 mb-3">{{ form_row(form.editora) }}</div>
                <div class="col-md-4 mb-3">{{ form_row(form.anoPublicacao) }}</div>
                <div class="col-md-4 mb-3">{{ form_row(form.preco) }}</div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">{{ form_row(form.autores) }}</div>
                <div class="col-md-6 mb-3">{{ form_row(form.assuntos) }}</div>
            </div>
            <button type="submit" class="btn btn-success"><i class="bi bi-check-lg"></i> Salvar</button>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}
