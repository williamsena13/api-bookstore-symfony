{% extends 'admin/layout.html.twig' %}
{% block title %}Assuntos — {{ livraria.nome ?? 'Bookstore' }}{% endblock %}
{% block page_title %}Assuntos{% endblock %}
{% block breadcrumb %}<i class="pi pi-angle-right"></i> Assuntos{% endblock %}

{% block content %}
<div class="p-card">
    <div class="p-card-header">
        <h2 class="p-card-title"><i class="pi pi-tag"></i> Assuntos</h2>
        <div class="d-flex align-items-center gap-2">
            <span style="font-size:.82rem;color:var(--text-secondary);">{{ paginacao.total }} assuntos</span>
            <button class="p-btn p-btn-success p-btn-sm btn-modal" data-url="{{ path('app_assunto_new') }}" data-title="Novo Assunto">
                <i class="pi pi-plus"></i> Novo Assunto
            </button>
        </div>
    </div>

    <div class="p-card-body" style="padding:0;">
        <div class="dt-wrapper">
            <table class="table table-striped table-bordered table-hover mb-0">
                <thead>
                    <tr>
                        <th style="width:60px;">#</th>
                        <th>Descrição</th>
                        <th style="width:110px;">Livros</th>
                        <th style="width:140px;">Criado em</th>
                        <th style="width:90px;">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    {% for assunto in paginacao.items %}
                    <tr>
                        <td class="text-muted">{{ assunto.id }}</td>
                        <td><strong>{{ assunto.descricao }}</strong></td>
                        <td>
                            {% if assunto.total_livros > 0 %}
                                <span class="p-badge p-badge-primary"><i class="pi pi-book"></i> {{ assunto.total_livros }}</span>
                            {% else %}
                                <span class="p-badge p-badge-secondary">0</span>
                            {% endif %}
                        </td>
                        <td class="text-muted" style="font-size:.8rem;">{{ assunto.created_at|date('d/m/Y H:i') }}</td>
                        <td>
                            <div class="flex gap-1">
                                <a href="{{ path('app_assunto_edit', {id: assunto.id}) }}" class="p-btn p-btn-warning p-btn-sm" title="Editar">
                                    <i class="pi pi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('app_assunto_delete', {id: assunto.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ assunto.id) }}">
                                    <button type="button" class="p-btn p-btn-danger p-btn-sm btn-delete" data-label='"{{ assunto.descricao }}"' title="Excluir">
                                        <i class="pi pi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="5" style="text-align:center;padding:2rem;color:var(--text-secondary);">Nenhum assunto cadastrado.</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {% include 'admin/_pagination.html.twig' %}
</div>

{% include 'admin/_modals.html.twig' %}
{% endblock %}

{% block javascripts %}
<script src="/js/modal-crud.js"></script>
{% endblock %}
