<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ livraria.nome ?? 'Bookstore' }}{% endblock %}</title>
    {% if livraria.favicon %}<link rel="icon" href="{{ livraria.favicon }}">{% endif %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/primeicons@7.0.0/primeicons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.datatables.net/2.0.8/css/dataTables.dataTables.min.css" rel="stylesheet">
    <link href="/css/landing.css" rel="stylesheet">
    {% include '_theme_css.html.twig' %}
    {% block stylesheets %}{% endblock %}
</head>
<body class="pub-body">

<nav class="pub-nav">
    <div class="container d-flex justify-content-between align-items-center">
        <a href="{{ path('app_home') }}" class="pub-nav-brand">
            <i class="pi pi-book"></i>
            <span>{{ livraria.nome ?? 'Bookstore' }}</span>
        </a>

        <button class="pub-nav-toggle" id="pubNavToggle" aria-label="Menu">
            <span></span><span></span><span></span>
        </button>

        <div class="pub-nav-collapse" id="pubNavCollapse">
            <a href="{{ path('app_home') }}" class="pub-nav-link {% block nav_home %}{% endblock %}">
                <i class="pi pi-home"></i> Início
            </a>
            <a href="{{ path('app_public_livros') }}" class="pub-nav-link {% block nav_livros %}{% endblock %}">
                <i class="pi pi-book"></i> Livros
            </a>
            <a href="{{ path('app_public_autores') }}" class="pub-nav-link {% block nav_autores %}{% endblock %}">
                <i class="pi pi-user"></i> Autores
            </a>
            <a href="{{ path('app_public_editoras') }}" class="pub-nav-link {% block nav_editoras %}{% endblock %}">
                <i class="pi pi-building"></i> Editoras
            </a>
            <a href="{{ path('app_public_assuntos') }}" class="pub-nav-link {% block nav_assuntos %}{% endblock %}">
                <i class="pi pi-tag"></i> Assuntos
            </a>

            {# Dropdown Relatórios #}
            <div class="pub-nav-dropdown" id="relDropdown">
                <button class="pub-nav-link pub-nav-dropdown-btn {% block nav_relatorios %}{% endblock %}" type="button">
                    <i class="pi pi-chart-bar"></i> Relatórios <i class="pi pi-chevron-down" style="font-size:.65rem;"></i>
                </button>
                <div class="pub-nav-dropdown-menu" id="relDropdownMenu">
                    <a href="{{ path('app_public_relatorio_por_autor') }}" class="pub-nav-dropdown-item">
                        <i class="pi pi-user"></i> Por Autor
                    </a>
                    <a href="{{ path('app_public_relatorio_por_editora') }}" class="pub-nav-dropdown-item">
                        <i class="pi pi-building"></i> Por Editora
                    </a>
                    <a href="{{ path('app_public_relatorio_por_assunto') }}" class="pub-nav-dropdown-item">
                        <i class="pi pi-tag"></i> Por Assunto
                    </a>
                    <div class="pub-nav-dropdown-divider"></div>
                    <a href="{{ path('app_public_relatorio_ranking') }}" class="pub-nav-dropdown-item">
                        <i class="pi pi-star"></i> Rankings
                    </a>
                </div>
            </div>

            <a href="{{ path('app_login') }}" class="pub-nav-cta">
                <i class="pi pi-sign-in"></i> Entrar
            </a>
        </div>
    </div>
</nav>

<main>{% block content %}{% endblock %}</main>

<footer class="pub-footer">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
        <span><i class="pi pi-book"></i> {{ livraria.nome ?? 'Bookstore' }}</span>
        <span>Desenvolvido por <strong>William B. Sena</strong> · Symfony 6.4</span>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
<script src="https://cdn.datatables.net/2.0.8/js/dataTables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script src="/js/pub-pagination.js"></script>
<script>
// Toggle pub-nav mobile
(function () {
    var toggle = document.getElementById('pubNavToggle');
    var collapse = document.getElementById('pubNavCollapse');
    if (!toggle || !collapse) return;
    toggle.addEventListener('click', function () {
        this.classList.toggle('open');
        collapse.classList.toggle('open');
    });
    document.addEventListener('click', function (e) {
        if (!toggle.contains(e.target) && !collapse.contains(e.target)) {
            toggle.classList.remove('open');
            collapse.classList.remove('open');
        }
    });
})();

// Dropdown relatórios
(function () {
    var btn = document.querySelector('.pub-nav-dropdown-btn');
    var menu = document.getElementById('relDropdownMenu');
    if (!btn || !menu) return;
    btn.addEventListener('click', function (e) {
        e.stopPropagation();
        menu.classList.toggle('open');
    });
    document.addEventListener('click', function () { menu.classList.remove('open'); });
})();

// Toggle pub-table-card — inicia colapsado
document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.pub-table-card-header[data-toggle]').forEach(function (header) {
        // Fecha por padrão
        header.closest('.pub-table-card').classList.add('collapsed');

        header.addEventListener('click', function () {
            this.closest('.pub-table-card').classList.toggle('collapsed');
        });
    });
});
</script>
{% block javascripts %}{% endblock %}
</body>
</html>
