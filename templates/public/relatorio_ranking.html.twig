{% extends 'public/layout.html.twig' %}
{% block title %}Rankings — {{ livraria.nome ?? 'Bookstore' }}{% endblock %}
{% block nav_relatorios %}active{% endblock %}

{% block content %}
<div class="pub-page-hero">
    <div class="container d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h1 class="pub-page-hero-title"><i class="pi pi-star"></i> Rankings</h1>
            <p class="pub-page-hero-sub">Top autores, editoras, assuntos e livros</p>
        </div>
        <a href="{{ path('app_public_relatorios') }}" class="pub-back-link"><i class="pi pi-arrow-left"></i> Relatórios</a>
    </div>
</div>

<div class="container py-4">
    <div class="row g-3">
        {% set tables = [
            {title: 'Top Autores',       icon: 'pi-user',     color: '#6366f1', data: autorMaisLivros,   key_name: 'nome',      key_val: 'total',  label_val: 'Livros'},
            {title: 'Top Editoras',      icon: 'pi-building', color: '#22c55e', data: editoraMaisLivros, key_name: 'nome',      key_val: 'total',  label_val: 'Livros'},
            {title: 'Top Assuntos',      icon: 'pi-tag',      color: '#ef4444', data: assuntoMaisLivros, key_name: 'descricao', key_val: 'total',  label_val: 'Livros'},
            {title: 'Livros Mais Caros', icon: 'pi-dollar',   color: '#f59e0b', data: livroMaisCaro,     key_name: 'titulo',    key_val: 'preco',  label_val: 'Preço'},
        ] %}
        {% for t in tables %}
        <div class="col-lg-6">
            <div class="pub-table-card">
                <div class="pub-table-card-header">
                    <span><i class="pi {{ t.icon }}" style="color:{{ t.color }};margin-right:.4rem;"></i>{{ t.title }}</span>
                </div>
                <div class="dt-wrapper">
                    <table class="p-datatable w-full" data-order="0,asc">
                        <thead><tr><th style="width:50px;">#</th><th>Nome</th><th>{{ t.label_val }}</th></tr></thead>
                        <tbody>
                            {% for i, r in t.data %}
                            <tr>
                                <td><span style="font-weight:700;color:{{ i < 3 ? '#f59e0b' : '#64748b' }};">{{ i + 1 }}º</span></td>
                                <td><strong>{{ attribute(r, t.key_name) }}</strong></td>
                                <td>
                                    {% if t.key_val == 'preco' %}
                                        <span style="color:#22c55e;font-weight:600;">R$ {{ attribute(r, t.key_val)|number_format(2, ',', '.') }}</span>
                                    {% else %}
                                        {{ attribute(r, t.key_val) }}
                                    {% endif %}
                                </td>
                            </tr>
                            {% else %}
                            <tr><td colspan="3" style="text-align:center;padding:1.5rem;color:#64748b;">Nenhum dado.</td></tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
{% block javascripts %}<script src="/js/datatable.js"></script>{% endblock %}
