{% extends 'public/layout.html.twig' %}
{% block title %}Autores — {{ livraria.nome ?? 'Bookstore' }}{% endblock %}
{% block nav_autores %}active{% endblock %}

{% block content %}
<div class="pub-page-hero">
    <div class="container">
        <h1 class="pub-page-hero-title"><i class="pi pi-user"></i> Autores</h1>
        <p class="pub-page-hero-sub">{{ autores|length }} autores cadastrados</p>
    </div>
</div>

<div class="container py-4">
    <div class="row g-3" data-card-grid data-page-size="12">
        {% for a in autores %}
        <div class="col-xl-3 col-lg-4 col-md-6">
            <div class="pub-grid-card">
                <div class="pub-grid-card-cover" style="background:linear-gradient(135deg,#065f46,#047857);">
                    <div class="pub-grid-card-icon"><i class="pi pi-user"></i></div>
                    <p class="pub-grid-card-title">{{ a.nome }}</p>
                </div>
                <div class="pub-grid-card-body">
                    <div class="pub-grid-card-count">
                        <i class="pi pi-book"></i>
                        {{ a.total_livros }} livro{{ a.total_livros != 1 ? 's' : '' }}
                    </div>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-12 text-center py-5" style="color:#64748b;">
            <i class="pi pi-inbox" style="font-size:2.5rem;display:block;margin-bottom:.75rem;"></i>
            Nenhum autor cadastrado.
        </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
