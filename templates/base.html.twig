<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{{ livraria.descricao ?? 'Sistema de Gerenciamento de Livros' }}">
    <meta name="author" content="William B. Sena">
    <title>{% block title %}{{ livraria.nome ?? 'Bookstore' }}{% endblock %}</title>
