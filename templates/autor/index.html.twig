{% extends 'admin/layout.html.twig' %}

{% block title %}Autores — {{ livraria.nome ?? 'Bookstore' }}{% endblock %}

{% block content %}
<div id="alert-container"></div>
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Autores</h2>
    <button class="btn btn-success btn-modal" data-url="{{ path('app_autor_new') }}" data-title="Novo Autor">
        <i class="bi bi-plus-lg"></i> Novo Autor
    </button>
</div>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Nome</th>
                    <th>Criado em</th>
                    <th class="text-end">Ações</th>
                </tr>
            </thead>
            <tbody>
                {% for autor in autores %}
                <tr>
                    <td>{{ autor.id }}</td>
                    <td>{{ autor.nome }}</td>
                    <td>{{ autor.createdAt|date('d/m/Y H:i') }}</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-warning btn-modal" data-url="{{ path('app_autor_edit', {id: autor.id}) }}" data-title="Editar Autor">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <form method="post" action="{{ path('app_autor_delete', {id: autor.id}) }}" class="d-inline" onsubmit="return confirm('Tem certeza que deseja excluir?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ autor.id) }}">
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="4" class="text-center text-muted py-4">Nenhum autor cadastrado.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="crudModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body"></div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{% include 'admin/_modal_js.html.twig' %}
{% endblock %}
