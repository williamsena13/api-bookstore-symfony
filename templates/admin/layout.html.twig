{% extends 'base.html.twig' %}

{% block body %}
<div class="d-flex">
    <div class="sidebar d-flex flex-column" style="width: 250px;">
        <div class="p-3 text-white fw-bold fs-5 border-bottom border-secondary">
            <i class="bi bi-book"></i> {{ livraria.nome ?? 'Bookstore' }}
        </div>
        <a href="{{ path('app_admin_dashboard') }}" class="{{ app.request.get('_route') == 'app_admin_dashboard' ? 'active' : '' }}">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>
        <a href="{{ path('app_assunto_index') }}" class="{{ app.request.get('_route') starts with 'app_assunto' ? 'active' : '' }}">
            <i class="bi bi-tags"></i> Assuntos
        </a>
        <a href="{{ path('app_editora_index') }}" class="{{ app.request.get('_route') starts with 'app_editora' ? 'active' : '' }}">
            <i class="bi bi-building"></i> Editoras
        </a>
        <a href="{{ path('app_autor_index') }}" class="{{ app.request.get('_route') starts with 'app_autor' ? 'active' : '' }}">
            <i class="bi bi-person"></i> Autores
        </a>
        <a href="{{ path('app_livro_index') }}" class="{{ app.request.get('_route') starts with 'app_livro' ? 'active' : '' }}">
            <i class="bi bi-journal-text"></i> Livros
        </a>
        <div class="border-top border-secondary mt-3 pt-2 px-3"><small class="text-secondary text-uppercase" style="font-size:.7rem;">Relatórios</small></div>
        <a href="{{ path('app_relatorio_index') }}" class="{{ app.request.get('_route') == 'app_relatorio_index' ? 'active' : '' }}">
            <i class="bi bi-bar-chart"></i> Painel
        </a>
        <a href="{{ path('app_relatorio_por_autor') }}" class="{{ app.request.get('_route') starts with 'app_relatorio_por_autor' ? 'active' : '' }}">
            <i class="bi bi-person-lines-fill"></i> Por Autor
        </a>
        <a href="{{ path('app_relatorio_por_editora') }}" class="{{ app.request.get('_route') starts with 'app_relatorio_por_editora' ? 'active' : '' }}">
            <i class="bi bi-building"></i> Por Editora
        </a>
        <a href="{{ path('app_relatorio_por_assunto') }}" class="{{ app.request.get('_route') starts with 'app_relatorio_por_assunto' ? 'active' : '' }}">
            <i class="bi bi-tags"></i> Por Assunto
        </a>
        <a href="{{ path('app_relatorio_ranking') }}" class="{{ app.request.get('_route') == 'app_relatorio_ranking' ? 'active' : '' }}">
            <i class="bi bi-trophy"></i> Rankings
        </a>
        <div class="border-top border-secondary mt-3 pt-2 px-3"><small class="text-secondary text-uppercase" style="font-size:.7rem;">Administração</small></div>
        <a href="{{ path('app_user_index') }}" class="{{ app.request.get('_route') starts with 'app_user' ? 'active' : '' }}">
            <i class="bi bi-people"></i> Usuários
        </a>
        <a href="{{ path('app_livraria_edit') }}" class="{{ app.request.get('_route') starts with 'app_livraria' ? 'active' : '' }}">
            <i class="bi bi-shop"></i> Livraria
        </a>
        <div class="mt-auto border-top border-secondary p-3">
            <small class="text-secondary">{{ app.user.nome ?? app.user.email }}</small>
            <a href="{{ path('app_logout') }}" class="text-danger mt-1"><i class="bi bi-box-arrow-left"></i> Sair</a>
        </div>
    </div>
    <div class="content flex-grow-1">
        {% for type in ['success', 'warning', 'danger'] %}
            {% for message in app.flashes(type) %}
                <div class="alert alert-{{ type }} alert-dismissible fade show">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
        {% block content %}{% endblock %}
    </div>
</div>
{% endblock %}
