{% extends 'base.html.twig' %}

{% block body %}
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<div class="admin-wrapper" id="adminWrapper">

    {# SIDEBAR #}
    <aside class="sidebar" id="adminSidebar">
        <a href="{{ path('app_admin_dashboard') }}" class="sidebar-brand">
            {% if livraria.logoNavbar %}
                <img src="{{ livraria.logoNavbar }}" alt="{{ livraria.nome }}" style="height:32px;max-width:32px;object-fit:contain;flex-shrink:0;">
                <span>{{ livraria.nome ?? 'Bookstore' }}</span>
            {% else %}
                <div class="brand-icon"><i class="pi pi-book"></i></div>
                <span>{{ livraria.nome ?? 'Bookstore' }}</span>
            {% endif %}
        </a>

        <nav class="sidebar-nav">
            <a href="{{ path('app_admin_dashboard') }}" class="sidebar-link {{ app.request.get('_route') == 'app_admin_dashboard' ? 'active' : '' }}">
                <i class="pi pi-home"></i> Dashboard
            </a>
            <a href="{{ path('app_home') }}" class="sidebar-link" target="_blank">
                <i class="pi pi-external-link"></i> Ver site
            </a>

            <div class="sidebar-section">Cadastros</div>
            <a href="{{ path('app_livro_index') }}" class="sidebar-link {{ app.request.get('_route') starts with 'app_livro' ? 'active' : '' }}">
                <i class="pi pi-book"></i> Livros
            </a>
            <a href="{{ path('app_autor_index') }}" class="sidebar-link {{ app.request.get('_route') starts with 'app_autor' ? 'active' : '' }}">
                <i class="pi pi-user"></i> Autores
            </a>
            <a href="{{ path('app_editora_index') }}" class="sidebar-link {{ app.request.get('_route') starts with 'app_editora' ? 'active' : '' }}">
                <i class="pi pi-building"></i> Editoras
            </a>
            <a href="{{ path('app_assunto_index') }}" class="sidebar-link {{ app.request.get('_route') starts with 'app_assunto' ? 'active' : '' }}">
                <i class="pi pi-tag"></i> Assuntos
            </a>

            <div class="sidebar-section">Relatórios</div>
            <a href="{{ path('app_relatorio_index') }}" class="sidebar-link {{ app.request.get('_route') == 'app_relatorio_index' ? 'active' : '' }}">
                <i class="pi pi-chart-bar"></i> Painel
            </a>
            <a href="{{ path('app_relatorio_por_autor') }}" class="sidebar-link {{ app.request.get('_route') starts with 'app_relatorio_por_autor' ? 'active' : '' }}">
                <i class="pi pi-users"></i> Por Autor
            </a>
            <a href="{{ path('app_relatorio_por_editora') }}" class="sidebar-link {{ app.request.get('_route') starts with 'app_relatorio_por_editora' ? 'active' : '' }}">
                <i class="pi pi-building"></i> Por Editora
            </a>
            <a href="{{ path('app_relatorio_por_assunto') }}" class="sidebar-link {{ app.request.get('_route') starts with 'app_relatorio_por_assunto' ? 'active' : '' }}">
                <i class="pi pi-tags"></i> Por Assunto
            </a>
            <a href="{{ path('app_relatorio_ranking') }}" class="sidebar-link {{ app.request.get('_route') == 'app_relatorio_ranking' ? 'active' : '' }}">
                <i class="pi pi-star"></i> Rankings
            </a>

            <div class="sidebar-section">Administração</div>
            <a href="{{ path('app_import_index') }}" class="sidebar-link {{ app.request.get('_route') starts with 'app_import' ? 'active' : '' }}">
                <i class="pi pi-cloud-download"></i> Importar Livros
            </a>
            <a href="{{ path('app_import_historico') }}" class="sidebar-link {{ app.request.get('_route') == 'app_import_historico' or app.request.get('_route') == 'app_import_detalhe' ? 'active' : '' }}">
                <i class="pi pi-history"></i> Histórico Import.
            </a>
            <a href="{{ path('app_user_index') }}" class="sidebar-link {{ app.request.get('_route') starts with 'app_user' ? 'active' : '' }}">
                <i class="pi pi-users"></i> Usuários
            </a>
            <a href="{{ path('app_livraria_edit') }}" class="sidebar-link {{ app.request.get('_route') starts with 'app_livraria' ? 'active' : '' }}">
                <i class="pi pi-cog"></i> Livraria
            </a>
        </nav>
    </aside>

    {# MAIN #}
    <main class="admin-main">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle" title="Menu">
                <i class="pi pi-align-justify"></i>
            </button>
            <div class="topbar-breadcrumb">
                <a href="{{ path('app_admin_dashboard') }}">Dashboard</a>
                {% block breadcrumb %}{% endblock %}
            </div>

            <div class="topbar-title">{% block page_title %}{% endblock %}</div>

            <div class="topbar-actions">

                {# DARK MODE TOGGLE #}
                <button class="topbar-icon-btn" id="darkModeBtn" title="Alternar modo escuro">
                    <i class="pi pi-moon" id="darkModeIcon"></i>
                </button>

                {# USER DROPDOWN #}
                <div class="topbar-user" id="userDropdown">
                    <button class="topbar-user-btn" id="userDropdownBtn" aria-expanded="false">
                        {% if app.user.foto is defined and app.user.foto %}
                            <img src="{{ app.user.foto }}" class="topbar-avatar-img" alt="{{ app.user.nome }}">
                        {% else %}
                            <div class="topbar-avatar">{{ (app.user.nome ?? app.user.email)|first|upper }}</div>
                        {% endif %}
                        <div class="topbar-user-info">
                            <span class="topbar-user-name">{{ app.user.nome ?? app.user.email }}</span>
                            <span class="topbar-user-role">Administrador</span>
                        </div>
                        <i class="pi pi-chevron-down topbar-chevron"></i>
                    </button>
                    <div class="topbar-dropdown" id="userDropdownMenu">
                        <div class="topbar-dropdown-header">
                            {% if app.user.foto is defined and app.user.foto %}
                                <img src="{{ app.user.foto }}" class="topbar-dropdown-avatar-img" alt="{{ app.user.nome }}">
                            {% else %}
                                <div class="topbar-dropdown-avatar">{{ (app.user.nome ?? app.user.email)|first|upper }}</div>
                            {% endif %}
                            <div>
                                <div class="topbar-dropdown-name">{{ app.user.nome ?? '—' }}</div>
                                <div class="topbar-dropdown-email">{{ app.user.email }}</div>
                            </div>
                        </div>
                        <div class="topbar-dropdown-divider"></div>
                        <a href="{{ path('app_profile') }}" class="topbar-dropdown-item">
                            <i class="pi pi-user-edit"></i> Meu Perfil
                        </a>
                        <a href="{{ path('app_livraria_edit') }}" class="topbar-dropdown-item">
                            <i class="pi pi-cog"></i> Configurações
                        </a>
                        <div class="topbar-dropdown-divider"></div>
                        <a href="{{ path('app_logout') }}" class="topbar-dropdown-item topbar-dropdown-item-danger">
                            <i class="pi pi-sign-out"></i> Sair
                        </a>
                    </div>
                </div>
            </div>
        </header>

        <div class="page-content">
            <div id="alert-container">
                {% for type in ['success', 'warning', 'danger'] %}
                    {% for message in app.flashes(type) %}
                        <div class="p-alert p-alert-{{ type == 'danger' ? 'danger' : (type == 'warning' ? 'warning' : 'success') }}">
                            <i class="pi pi-{{ type == 'danger' ? 'times-circle' : (type == 'warning' ? 'exclamation-triangle' : 'check-circle') }}"></i>
                            {{ message }}
                        </div>
                    {% endfor %}
                {% endfor %}
            </div>
            {% block content %}{% endblock %}
        </div>
    </main>

</div>

<script src="/js/admin-theme.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    // Sidebar toggle mobile
    var toggle = document.getElementById('sidebarToggle');
    var sidebar = document.getElementById('adminSidebar');
    var overlay = document.getElementById('sidebarOverlay');
    function closeSidebar() {
        sidebar.classList.remove('open');
        overlay.classList.remove('open');
    }
    if (toggle) {
        toggle.addEventListener('click', function () {
            sidebar.classList.toggle('open');
            overlay.classList.toggle('open');
        });
    }
    if (overlay) {
        overlay.addEventListener('click', closeSidebar);
    }
    // Fechar sidebar ao clicar em link no mobile
    document.querySelectorAll('.sidebar-link').forEach(function (link) {
        link.addEventListener('click', function () {
            if (window.innerWidth <= 768) closeSidebar();
        });
    });

    // User dropdown
    var btn = document.getElementById('userDropdownBtn');
    var menu = document.getElementById('userDropdownMenu');
    if (btn && menu) {
        btn.addEventListener('click', function (e) {
            e.stopPropagation();
            var open = menu.classList.toggle('open');
            btn.setAttribute('aria-expanded', open);
            btn.querySelector('.topbar-chevron').style.transform = open ? 'rotate(180deg)' : '';
        });
        document.addEventListener('click', function () {
            menu.classList.remove('open');
            btn.setAttribute('aria-expanded', false);
            btn.querySelector('.topbar-chevron').style.transform = '';
        });
    }
});
</script>
{% endblock %}
