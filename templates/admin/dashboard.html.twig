{% extends 'admin/layout.html.twig' %}

{% block title %}Dashboard — Bookstore{% endblock %}

{% block content %}
<h2 class="mb-4">Dashboard</h2>
<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="bg-primary bg-opacity-10 rounded-3 p-3 me-3">
                    <i class="bi bi-tags fs-2 text-primary"></i>
                </div>
                <div>
                    <h3 class="mb-0">{{ totalAssuntos }}</h3>
                    <small class="text-muted">Assuntos cadastrados</small>
                </div>
                <a href="{{ path('app_assunto_index') }}" class="ms-auto btn btn-sm btn-outline-primary">Ver todos</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="bg-success bg-opacity-10 rounded-3 p-3 me-3">
                    <i class="bi bi-building fs-2 text-success"></i>
                </div>
                <div>
                    <h3 class="mb-0">{{ totalEditoras }}</h3>
                    <small class="text-muted">Editoras cadastradas</small>
                </div>
                <a href="{{ path('app_editora_index') }}" class="ms-auto btn btn-sm btn-outline-success">Ver todas</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="bg-warning bg-opacity-10 rounded-3 p-3 me-3">
                    <i class="bi bi-person fs-2 text-warning"></i>
                </div>
                <div>
                    <h3 class="mb-0">{{ totalAutores }}</h3>
                    <small class="text-muted">Autores cadastrados</small>
                </div>
                <a href="{{ path('app_autor_index') }}" class="ms-auto btn btn-sm btn-outline-warning">Ver todos</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
