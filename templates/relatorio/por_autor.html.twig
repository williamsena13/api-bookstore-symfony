{% extends 'admin/layout.html.twig' %}
{% block title %}Relatório por Autor — {{ livraria.nome ?? 'Bookstore' }}{% endblock %}
{% block page_title %}Relatório por Autor{% endblock %}
{% block breadcrumb %}<i class="pi pi-angle-right"></i> <a href="{{ path('app_relatorio_index') }}">Relatórios</a> <i class="pi pi-angle-right"></i> Por Autor{% endblock %}

{% set totalLivros = 0 %}
{% set totalValor = 0.0 %}
{% for autorNome, livros in agrupado %}
    {% set totalLivros = totalLivros + livros|length %}
    {% for l in livros %}{% if l.preco %}{% set totalValor = totalValor + l.preco %}{% endif %}{% endfor %}
{% endfor %}

{% block content %}

{# TOOLBAR #}
<div class="flex align-items-center justify-content-between mb-4 no-print flex-wrap gap-2">
    <div class="flex gap-2">
        <a href="{{ path('app_relatorio_por_autor_pdf') }}" target="_blank" class="p-btn p-btn-danger p-btn-sm">
            <i class="pi pi-file-pdf"></i> Exportar PDF
        </a>
        <button onclick="exportCSV()" class="p-btn p-btn-success p-btn-sm">
            <i class="pi pi-download"></i> Exportar CSV
        </button>
        <button onclick="window.print()" class="p-btn p-btn-secondary p-btn-sm">
            <i class="pi pi-print"></i> Imprimir
        </button>
    </div>
    <a href="{{ path('app_relatorio_index') }}" class="p-btn p-btn-secondary p-btn-sm">
        <i class="pi pi-arrow-left"></i> Voltar
    </a>
</div>

{# STAT CARDS #}
<div class="grid mb-4">
    <div class="col-12 md:col-4">
        <div class="stat-card">
            <div class="stat-icon" style="background:#eef2ff;"><i class="pi pi-users" style="color:#6366f1;font-size:1.4rem;"></i></div>
            <div><div class="stat-value">{{ agrupado|length }}</div><div class="stat-label">Autores</div></div>
        </div>
    </div>
    <div class="col-12 md:col-4">
        <div class="stat-card">
            <div class="stat-icon" style="background:#dcfce7;"><i class="pi pi-book" style="color:#22c55e;font-size:1.4rem;"></i></div>
            <div><div class="stat-value">{{ totalLivros }}</div><div class="stat-label">Livros</div></div>
        </div>
    </div>
    <div class="col-12 md:col-4">
        <div class="stat-card">
            <div class="stat-icon" style="background:#fef3c7;"><i class="pi pi-dollar" style="color:#f59e0b;font-size:1.4rem;"></i></div>
            <div><div class="stat-value" style="font-size:1.2rem;">R$ {{ totalValor|number_format(2, ',', '.') }}</div><div class="stat-label">Valor total</div></div>
        </div>
    </div>
</div>

{# GRÁFICOS #}
<div class="grid mb-4">
    <div class="col-12 lg:col-7">
        <div class="chart-card">
            <div class="chart-card-title"><i class="pi pi-chart-bar" style="color:#6366f1;"></i> Livros por Autor</div>
            <div class="chart-card-subtitle">Quantidade de títulos por autor</div>
            <div class="chart-container" style="height:260px;"><canvas id="chartAutorBar"></canvas></div>
        </div>
    </div>
    <div class="col-12 lg:col-5">
        <div class="chart-card">
            <div class="chart-card-title"><i class="pi pi-chart-pie" style="color:#22c55e;"></i> Participação por Autor</div>
            <div class="chart-card-subtitle">Proporção do acervo por autor</div>
            <div class="chart-container" style="height:260px;"><canvas id="chartAutorPie"></canvas></div>
        </div>
    </div>
</div>

{# TABELA #}
{% if agrupado|length > 0 %}
{% for autorNome, livros in agrupado %}
<div class="p-card mb-3">
    <div class="p-card-header" style="background:#1e1e2e;">
        <span style="color:#fff;font-weight:600;"><i class="pi pi-user" style="color:#6366f1;"></i> {{ autorNome }}</span>
        <span class="p-badge p-badge-primary">{{ livros|length }} livro{{ livros|length > 1 ? 's' : '' }}</span>
    </div>
    <div class="p-card-body" style="padding:0;">
        <div class="dt-wrapper">
            <table class="p-datatable w-full" data-sortable="[0,1,2,3,4]">
                <thead>
                    <tr><th>Título</th><th>Editora</th><th>Ed.</th><th>Ano</th><th>Preço</th><th>Assuntos</th></tr>
                </thead>
                <tbody>
                    {% for l in livros %}
                    <tr>
                        <td><strong>{{ l.livro_titulo }}</strong></td>
                        <td>{{ l.editora ?? '—' }}</td>
                        <td>{{ l.edicao ? l.edicao ~ 'ª' : '—' }}</td>
                        <td>{{ l.ano_publicacao ?? '—' }}</td>
                        <td>{% if l.preco %}<span style="color:var(--success);font-weight:600;">R$ {{ l.preco|number_format(2, ',', '.') }}</span>{% else %}—{% endif %}</td>
                        <td>{{ l.assuntos|default('—') }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endfor %}
{% else %}
<div class="p-card p-card-body text-center" style="color:var(--text-secondary);padding:3rem;">
    <i class="pi pi-info-circle" style="font-size:2rem;"></i>
    <p class="mt-2">Nenhum dado para exibir.</p>
</div>
{% endif %}

{% endblock %}

{% block javascripts %}
<script src="/js/datatable.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const palette = ['#6366f1','#22c55e','#f59e0b','#ef4444','#06b6d4','#a855f7','#f97316','#14b8a6','#ec4899','#84cc16'];
    const labels = {{ agrupado|keys|json_encode|raw }};
    const totais = [{% for autorNome, livros in agrupado %}{{ livros|length }},{% endfor %}];

    new Chart(document.getElementById('chartAutorBar'), {
        type: 'bar',
        data: {
            labels: labels,
            datasets: [{ label: 'Livros', data: totais, backgroundColor: palette.map(c => c + '33'), borderColor: palette, borderWidth: 2, borderRadius: 6 }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: { y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.05)' } }, x: { grid: { display: false } } }
        }
    });

    new Chart(document.getElementById('chartAutorPie'), {
        type: 'doughnut',
        data: {
            labels: labels,
            datasets: [{ data: totais, backgroundColor: palette, borderWidth: 0, hoverOffset: 8 }]
        },
        options: {
            responsive: true, maintainAspectRatio: false, cutout: '55%',
            plugins: { legend: { position: 'bottom', labels: { padding: 10, boxWidth: 12, font: { size: 11 } } } }
        }
    });
});

function exportCSV() {
    const rows = [['Autor','Título','Editora','Edição','Ano','Preço','Assuntos']];
    {% for autorNome, livros in agrupado %}
    {% for l in livros %}
    rows.push([
        '{{ autorNome|replace({"'": "'"}) }}',
        '{{ l.livro_titulo|replace({"'": "'"}) }}',
        '{{ (l.editora ?? '')|replace({"'": "'"}) }}',
        '{{ l.edicao ?? '' }}',
        '{{ l.ano_publicacao ?? '' }}',
        '{{ l.preco ?? '' }}',
        '{{ (l.assuntos ?? '')|replace({"'": "'"}) }}'
    ]);
    {% endfor %}
    {% endfor %}
    const csv = rows.map(r => r.map(v => '"' + String(v).replace(/"/g, '""') + '"').join(',')).join('\n');
    const a = document.createElement('a');
    a.href = 'data:text/csv;charset=utf-8,\uFEFF' + encodeURIComponent(csv);
    a.download = 'relatorio-por-autor.csv';
    a.click();
}
</script>
{% endblock %}
