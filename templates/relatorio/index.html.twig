{% extends 'admin/layout.html.twig' %}
{% block title %}Relatórios — {{ livraria.nome ?? 'Bookstore' }}{% endblock %}

{% block content %}
<h2 class="mb-4">Relatórios</h2>
<div class="row g-4">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5><i class="bi bi-person text-primary"></i> Livros por Autor</h5>
                <p class="text-muted small">Relatório de livros agrupados por autor com detalhes de editora, edição e assuntos.</p>
                <a href="{{ path('app_relatorio_por_autor') }}" class="btn btn-outline-primary btn-sm"><i class="bi bi-eye"></i> Visualizar</a>
                <a href="{{ path('app_relatorio_por_autor_pdf') }}" target="_blank" class="btn btn-outline-danger btn-sm"><i class="bi bi-file-pdf"></i> PDF</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5><i class="bi bi-building text-success"></i> Livros por Editora</h5>
                <p class="text-muted small">Relatório de livros agrupados por editora com autores e assuntos vinculados.</p>
                <a href="{{ path('app_relatorio_por_editora') }}" class="btn btn-outline-success btn-sm"><i class="bi bi-eye"></i> Visualizar</a>
                <a href="{{ path('app_relatorio_por_editora_pdf') }}" target="_blank" class="btn btn-outline-danger btn-sm"><i class="bi bi-file-pdf"></i> PDF</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5><i class="bi bi-tags text-warning"></i> Livros por Assunto</h5>
                <p class="text-muted small">Relatório de livros agrupados por assunto com autores e editoras vinculados.</p>
                <a href="{{ path('app_relatorio_por_assunto') }}" class="btn btn-outline-warning btn-sm"><i class="bi bi-eye"></i> Visualizar</a>
                <a href="{{ path('app_relatorio_por_assunto_pdf') }}" target="_blank" class="btn btn-outline-danger btn-sm"><i class="bi bi-file-pdf"></i> PDF</a>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h5><i class="bi bi-trophy text-info"></i> Rankings</h5>
                <p class="text-muted small">Rankings dos autores, editoras e assuntos com mais livros, e livros mais caros.</p>
                <a href="{{ path('app_relatorio_ranking') }}" class="btn btn-outline-info btn-sm"><i class="bi bi-eye"></i> Visualizar</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
