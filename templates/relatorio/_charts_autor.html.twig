{# Componente: gráficos bar+pie por autor #}
<div class="row g-3 mb-4">
    <div class="col-lg-7">
        <div class="public-card" style="padding:1.5rem;">
            <div style="font-size:.9rem;font-weight:600;color:#f1f5f9;margin-bottom:.25rem;"><i class="pi pi-chart-bar" style="color:#6366f1;"></i> Livros por Autor</div>
            <div style="font-size:.78rem;color:#64748b;margin-bottom:1rem;">Quantidade de títulos por autor</div>
            <div style="position:relative;height:260px;"><canvas id="chartAutorBar"></canvas></div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="public-card" style="padding:1.5rem;">
            <div style="font-size:.9rem;font-weight:600;color:#f1f5f9;margin-bottom:.25rem;"><i class="pi pi-chart-pie" style="color:#22c55e;"></i> Participação</div>
            <div style="font-size:.78rem;color:#64748b;margin-bottom:1rem;">Proporção do acervo por autor</div>
            <div style="position:relative;height:260px;"><canvas id="chartAutorPie"></canvas></div>
        </div>
    </div>
</div>
