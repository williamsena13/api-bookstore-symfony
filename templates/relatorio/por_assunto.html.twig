{% extends 'admin/layout.html.twig' %}
{% block title %}Relatório por Assunto — {{ livraria.nome ?? 'Bookstore' }}{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Livros por Assunto</h2>
    <div class="d-flex gap-2">
        <a href="{{ path('app_relatorio_por_assunto_pdf') }}" target="_blank" class="btn btn-danger btn-sm no-print"><i class="bi bi-file-pdf"></i> Exportar PDF</a>
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm no-print"><i class="bi bi-printer"></i> Imprimir</button>
        <a href="{{ path('app_relatorio_index') }}" class="btn btn-outline-primary btn-sm no-print"><i class="bi bi-arrow-left"></i> Voltar</a>
    </div>
</div>

{% for assunto, livros in agrupado %}
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header text-white" style="background:#E65100;">
        <i class="bi bi-tag"></i> {{ assunto }} <span class="badge bg-light text-dark ms-2">{{ livros|length }}</span>
    </div>
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Título</th><th>Editora</th><th>Ed.</th><th>Ano</th><th>Preço</th><th>Autores</th></tr>
            </thead>
            <tbody>
                {% for l in livros %}
                <tr>
                    <td><strong>{{ l.livro_titulo }}</strong></td>
                    <td>{{ l.editora ?? '—' }}</td>
                    <td>{{ l.edicao ? l.edicao ~ 'ª' : '—' }}</td>
                    <td>{{ l.ano_publicacao ?? '—' }}</td>
                    <td class="text-success fw-bold">{{ l.preco ? ('R$ ' ~ l.preco|number_format(2, ',', '.')) : '—' }}</td>
                    <td>{{ l.autores|default('—') }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% else %}
<div class="card border-0 shadow-sm p-4 text-center text-muted">
    <i class="bi bi-info-circle fs-2"></i>
    <p class="mt-2">Nenhum dado para exibir.</p>
</div>
{% endfor %}
{% endblock %}
