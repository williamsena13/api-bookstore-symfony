{% extends 'base.html.twig' %}

{% block title %}{{ livraria.nome ?? 'Bookstore' }} — Sistema de Gerenciamento de Livros{% endblock %}

{% block stylesheets %}
<style>
    .landing-hero {
        background: linear-gradient(135deg, #212529 0%, #343a40 50%, #495057 100%);
        color: #fff;
        min-height: 92vh;
        display: flex;
        align-items: center;
    }
    .landing-hero h1 { font-size: 3rem; font-weight: 700; }
    .landing-hero .lead { font-size: 1.25rem; color: #adb5bd; }
    .feature-icon {
        width: 64px; height: 64px;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.5rem;
        background: #212529;
        color: #fff;
    }
    .feature-card {
        border: none;
        border-radius: 12px;
        transition: transform .2s, box-shadow .2s;
    }
    .feature-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,.1);
    }
    .tech-badge {
        display: inline-flex; align-items: center; gap: 6px;
        padding: 8px 16px;
        border-radius: 50px;
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        font-weight: 500;
        font-size: .9rem;
    }
    .section-title { font-weight: 700; margin-bottom: .5rem; }
    .section-subtitle { color: #6c757d; margin-bottom: 3rem; }
    .cta-section {
        background: #212529;
        color: #fff;
    }
    .landing-nav {
        background: rgba(33,37,41,.95);
        backdrop-filter: blur(8px);
    }
    .stat-number { font-size: 2rem; font-weight: 700; color: #fff; }
    .stat-label { font-size: .85rem; color: #adb5bd; }
</style>
{% endblock %}

{% block body %}
{# Navbar #}
<nav class="navbar navbar-expand-lg navbar-dark landing-nav fixed-top">
    <div class="container">
        <a class="navbar-brand fw-bold" href="#"><i class="bi bi-book"></i> {{ livraria.nome ?? 'Bookstore' }}</a>
        <button class="navbar-toggler" data-bs-toggle="collapse" data-bs-target="#navLanding">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navLanding">
            <ul class="navbar-nav ms-auto me-3">
                <li class="nav-item"><a class="nav-link" href="#funcionalidades">Funcionalidades</a></li>
                <li class="nav-item"><a class="nav-link" href="#tecnologias">Tecnologias</a></li>
                <li class="nav-item"><a class="nav-link" href="#estrutura">Estrutura</a></li>
            </ul>
            <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-sm px-3">
                <i class="bi bi-box-arrow-in-right"></i> Entrar
            </a>
        </div>
    </div>
</nav>

{# Hero #}
<section class="landing-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <span class="badge bg-light text-dark mb-3 px-3 py-2 rounded-pill">
                    <i class="bi bi-stars"></i> Sistema MVP
                </span>
                <h1>Gerencie sua <span style="color:#0d6efd;">livraria</span> de forma simples e eficiente</h1>
                <p class="lead mt-3 mb-4">
                    CRUD completo de Livros, Autores, Editoras e Assuntos com painel administrativo,
                    relatórios e controle de acesso — tudo em uma interface moderna e intuitiva.
                </p>
                <div class="d-flex gap-3 flex-wrap">
                    <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg px-4">
                        <i class="bi bi-rocket-takeoff"></i> Acessar o Sistema
                    </a>
                    <a href="#funcionalidades" class="btn btn-outline-light btn-lg px-4">
                        <i class="bi bi-arrow-down-circle"></i> Saiba Mais
                    </a>
                </div>
            </div>
            <div class="col-lg-5 mt-5 mt-lg-0 text-center">
                <div class="row g-3">
                    <div class="col-6">
                        <div class="p-3 rounded-3" style="background:rgba(255,255,255,.08);">
                            <div class="stat-number"><i class="bi bi-journal-text"></i></div>
                            <div class="stat-label">Livros</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded-3" style="background:rgba(255,255,255,.08);">
                            <div class="stat-number"><i class="bi bi-person"></i></div>
                            <div class="stat-label">Autores</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded-3" style="background:rgba(255,255,255,.08);">
                            <div class="stat-number"><i class="bi bi-building"></i></div>
                            <div class="stat-label">Editoras</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="p-3 rounded-3" style="background:rgba(255,255,255,.08);">
                            <div class="stat-number"><i class="bi bi-bar-chart"></i></div>
                            <div class="stat-label">Relatórios</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

{# Funcionalidades #}
<section id="funcionalidades" class="py-5">
    <div class="container py-4">
        <div class="text-center">
            <h2 class="section-title">Funcionalidades</h2>
            <p class="section-subtitle">Tudo o que você precisa para gerenciar seu acervo</p>
        </div>
        <div class="row g-4">
            {% set features = [
                { icon: 'bi-shield-lock',       title: 'Autenticação Segura',   desc: 'Login com controle de acesso por perfil (ROLE_ADMIN) e proteção de rotas.' },
                { icon: 'bi-speedometer2',      title: 'Dashboard',             desc: 'Painel com visão geral e contadores de livros, autores, editoras e assuntos.' },
                { icon: 'bi-journal-text',      title: 'CRUD de Livros',        desc: 'Cadastro completo com relacionamento N:N para autores/assuntos e N:1 para editora.' },
                { icon: 'bi-person-lines-fill', title: 'CRUD de Autores',       desc: 'Gerenciamento de autores com listagem, criação, edição e exclusão.' },
                { icon: 'bi-building',          title: 'CRUD de Editoras',      desc: 'Controle de editoras vinculadas aos livros do acervo.' },
                { icon: 'bi-tags',              title: 'CRUD de Assuntos',      desc: 'Categorize seus livros por assuntos e temas diversos.' },
                { icon: 'bi-window-stack',      title: 'Modais AJAX',           desc: 'Formulários de criação e edição via modal com feedback instantâneo.' },
                { icon: 'bi-bar-chart-line',    title: 'Relatórios & Rankings', desc: 'Relatórios por autor, editora e assunto com exportação em PDF.' },
                { icon: 'bi-people',            title: 'Gestão de Usuários',    desc: 'Administração de usuários do sistema com controle de permissões.' }
            ] %}
            {% for f in features %}
            <div class="col-md-6 col-lg-4">
                <div class="card feature-card h-100 shadow-sm p-4">
                    <div class="feature-icon mb-3"><i class="bi {{ f.icon }}"></i></div>
                    <h5 class="fw-bold">{{ f.title }}</h5>
                    <p class="text-muted mb-0">{{ f.desc }}</p>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# Tecnologias #}
<section id="tecnologias" class="py-5 bg-white">
    <div class="container py-4">
        <div class="text-center">
            <h2 class="section-title">Tecnologias</h2>
            <p class="section-subtitle">Stack moderna e robusta</p>
        </div>
        <div class="d-flex flex-wrap justify-content-center gap-3">
            {% set techs = [
                { icon: 'bi-filetype-php', name: 'PHP 8.1+' },
                { icon: 'bi-symfony',      name: 'Symfony 6.4' },
                { icon: 'bi-database',     name: 'Doctrine ORM' },
                { icon: 'bi-layout-wtf',   name: 'Twig' },
                { icon: 'bi-bootstrap',    name: 'Bootstrap 5' },
                { icon: 'bi-server',       name: 'MySQL 8.0' }
            ] %}
            {% for t in techs %}
            <span class="tech-badge"><i class="bi {{ t.icon }}"></i> {{ t.name }}</span>
            {% endfor %}
        </div>
    </div>
</section>

{# Estrutura do Banco #}
<section id="estrutura" class="py-5">
    <div class="container py-4">
        <div class="text-center">
            <h2 class="section-title">Estrutura do Banco de Dados</h2>
            <p class="section-subtitle">Modelagem relacional bem definida</p>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="table-responsive">
                    <table class="table table-hover bg-white rounded shadow-sm overflow-hidden">
                        <thead class="table-dark">
                            <tr><th>Tabela</th><th>Descrição</th></tr>
                        </thead>
                        <tbody>
                            <tr><td><code>user</code></td><td>Usuários do sistema (autenticação)</td></tr>
                            <tr><td><code>livro</code></td><td>Livros do acervo</td></tr>
                            <tr><td><code>autor</code></td><td>Autores</td></tr>
                            <tr><td><code>editora</code></td><td>Editoras</td></tr>
                            <tr><td><code>assunto</code></td><td>Assuntos / categorias</td></tr>
                            <tr><td><code>livro_autor</code></td><td>Relacionamento Livro ↔ Autor (N:N)</td></tr>
                            <tr><td><code>livro_assunto</code></td><td>Relacionamento Livro ↔ Assunto (N:N)</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</section>

{# CTA Final #}
<section class="cta-section py-5">
    <div class="container py-4 text-center">
        <h2 class="fw-bold mb-3">Pronto para começar?</h2>
        <p class="text-secondary mb-4">Acesse o painel administrativo e gerencie seu acervo agora mesmo.</p>
        <a href="{{ path('app_login') }}" class="btn btn-primary btn-lg px-5">
            <i class="bi bi-box-arrow-in-right"></i> Acessar o Sistema
        </a>
    </div>
</section>

{# Footer #}
<footer class="py-4 bg-dark text-center">
    <small class="text-secondary">
        © {{ 'now'|date('Y') }} {{ livraria.nome ?? 'Bookstore' }} — Desenvolvido por William B. Sena
    </small>
</footer>
{% endblock %}
